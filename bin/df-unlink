#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")/.." && pwd)"

info() {
  printf "\033[1;32m[df-unlink]\033[0m %s\n" "$*"
}

warn() {
  printf "\033[1;33m[df-unlink]\033[0m %s\n" "$*"
}

unlink_if_symlink() {
    local path="$1"
    local confirm="${2:-}"

    if [[ ! -e "$path" && ! -L "$path" ]]; then
        return
    fi

    if [[ ! -L "$path" ]]; then
        warn "not a symlink (skipped): $path"
        return
    fi

    # 確認が必要な場合
    if [[ "$confirm" == "confirm" ]]; then
        read -p "$(printf "\033[1;33m[df-unlink]\033[0m unlink $path? [y/N]: ")" answer
        if [[ ! "$answer" =~ ^[yY]$ ]]; then
            info "skipped: $path"
            return
        fi
    fi

    rm "$path"
    info "unlinked: $path"

    # バックアップがあれば復元
    local backup_pattern="${path}.backup.*"
    local latest_backup=$(ls -t ${backup_pattern} 2>/dev/null | head -n 1 || true)
    if [[ -n "$latest_backup" ]]; then
        mv "$latest_backup" "$path"
        info "restored: $latest_backup -> $path"
    fi
}

# シンボリックリンクの削除（install.sh の setup_symlinks に対応）
unlink_if_symlink "$HOME/.p10k.zsh"
unlink_if_symlink "$HOME/.config/git/ignore"
unlink_if_symlink "$HOME/.nbrc"
unlink_if_symlink "$HOME/.zshenv" "confirm"
unlink_if_symlink "$HOME/.config/zsh"
unlink_if_symlink "$HOME/.config/sheldon/plugins.toml"
unlink_if_symlink "$HOME/.config/nvim"
unlink_if_symlink "$HOME/.config/zeno/config.yml"

# zsh補完キャッシュの削除
rm -f "$HOME/.zcompdump" "$HOME/.zcompdump.zwc" 2>/dev/null || true
info "zsh cache cleared"

info "done."
